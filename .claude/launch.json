{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "mkt-dashboard",
      "runtimeExecutable": ".venv/Scripts/streamlit.exe",
      "runtimeArgs": ["run", "mkt_dashboard.py", "--server.port", "8502", "--server.headless", "true"],
      "port": 8502
    },
    {
      "name": "shim-bridge",
      "runtimeExecutable": ".venv/Scripts/streamlit.exe",
      "runtimeArgs": ["run", "shim_app.py", "--server.port", "8503", "--server.headless", "true"],
      "port": 8503
    }
  ]
}
